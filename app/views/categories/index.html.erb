<h1>Browse By Category</h1>
<p>Select a category to view all products in it.</p>

<div class="list-group">
	<% @categories.each do |category| %>
		<%= link_to category_path(category), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>
			<span><%= category.name %></span>
			<span class="badge text-bg-secondary rounded-pill"><%= category.products.size %></span>
		<% end %>
	<% end %>
</div>

<div>
  <%= paginate @categories %>
</div>
