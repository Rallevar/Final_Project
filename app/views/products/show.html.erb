<h1><%= @product.product_name.to_s.tr("-", " ").titleize %></h1>

<p>
	<%= link_to "Back to Products", products_path %> |
	<%= link_to "More in #{@product.category.name}", category_path(@product.category) %>
</p>

<div class="row g-4 align-items-start">
	<div class="col-12 col-lg-5">
		<div class="rounded border overflow-hidden" style="height: 320px;">
			<%= render "products/product_image", product: @product %>
		</div>
	</div>

	<div class="col-12 col-lg-7">
		<%= render "products/product_summary", product: @product %>
		<p class="mb-2"><span class="fw-bold">Weight:</span> <%= @product.weight %></p>
		<p>
			<%= button_to "Add to Cart", add_item_orders_path(product_id: @product.id), method: :post, class: "btn btn-primary" %>
		</p>

		<hr>
		<h3>Description</h3>
		<p><%= @product.description %></p>
	</div>
</div>
