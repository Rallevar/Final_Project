<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card shadow-sm border-0 text-center">
      <div class="card-body p-4">
        <h1 class="mb-4">Customer Login</h1>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control text-center" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control text-center" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check d-flex justify-content-center align-items-center gap-2 mb-4">
              <%= f.check_box :remember_me, class: "form-check-input mt-0" %>
              <%= f.label :remember_me, class: "form-check-label mb-0" %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.submit "Log in", class: "shaded_links" %>
          </div>
        <% end %>

        <div>
          <p class="text-muted mb-2">If you do not have an account, click below to sign up.</p>
          <%= link_to "Sign up", new_customer_registration_path, class: "links" %>
        </div>
      </div>
    </div>
  </div>
</div>