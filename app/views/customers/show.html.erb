<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <div>
            <h1 class="h2 mb-1">My Account</h1>
            <p class="text-muted mb-0">View your customer account details below.</p>
          </div>
          <%= link_to "Edit Account Details", edit_customer_registration_path, class: "links" %>
        </div>

        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <tbody>
              <tr>
                <th class="w-25">Username</th>
                <td><%= @customer.user_name.presence || "Not provided" %></td>
              </tr>
              <tr>
                <th>Name</th>
                <td><%= @customer.name.presence || "Not provided" %></td>
              </tr>
              <tr>
                <th>Email</th>
                <td><%= @customer.email %></td>
              </tr>
              <tr>
                <th>Telephone</th>
                <td><%= @customer.telephone.presence || "Not provided" %></td>
              </tr>
              <tr>
                <th>Address</th>
                <td><%= @customer.address.presence || "Not provided" %></td>
              </tr>
              <tr>
                <th>Province</th>
                <td><%= @customer.province&.name || "Not provided" %></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mt-4">
          <%= link_to "Back to Home", root_path, class: "shaded_links" %>
        </div>
      </div>
    </div>
  </div>
</div>