<h1>Checkout</h1>

<%= form_with url: place_order_orders_path, method: :post, local: true do %>
  <div class="mb-3">
    <%= label_tag :shipping_address, "Shipping Address", class: "form-label" %>
    <%= text_field_tag :shipping_address, @shipping_address, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= label_tag :province_id, "Province", class: "form-label" %>
    <%= select_tag :province_id,
      options_from_collection_for_select(@provinces, :id, :name, @selected_province&.id),
      include_blank: "Select a Province",
      class: "form-select" %>
  </div>

  <h2>Invoice Preview</h2>

  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Product</th>
          <th>Quantity</th>
          <th>Unit Price</th>
          <th>Item Total</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr>
            <td><%= item[:product].product_name.to_s.tr("-", " ").titleize %></td>
            <td><%= item[:quantity] %></td>
            <td><%= number_to_currency(item[:product].cost) %></td>
            <td><%= number_to_currency(item[:item_total]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <p><span class="fw-bold">Subtotal:</span> <%= number_to_currency(@subtotal) %></p>
  <p><span class="fw-bold">GST:</span> <%= number_to_currency(@gst_amount) %></p>
  <p><span class="fw-bold">PST:</span> <%= number_to_currency(@pst_amount) %></p>
  <p><span class="fw-bold">HST:</span> <%= number_to_currency(@hst_amount) %></p>
  <p class="fs-5 fw-bold">Grand Total: <%= number_to_currency(@grand_total) %></p>

  <div class="d-flex gap-2">
    <%= submit_tag "Place Order", class: "shaded_links", id: "place_order_button" %>
    <%= link_to "Back to Cart", orders_path, class: "links" %>
  </div>
<% end %>