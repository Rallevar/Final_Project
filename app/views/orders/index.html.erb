<h1>Shopping Cart</h1>

<% if @cart_items.any? %>
	<div class="table-responsive">
		<table class="table table-striped align-middle">
			<thead>
				<tr>
					<th>Product</th>
					<th>Category</th>
					<th>Quantity</th>
					<th>Unit Price</th>
					<th>Item Total</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				<% @cart_items.each do |item| %>
					<tr>
						<td>
							<%= link_to item[:product].product_name.to_s.tr("-", " ").titleize, product_path(item[:product]) %>
						</td>
						<td><%= item[:product].category.name %></td>
						<td>
							<%= form_with url: update_item_orders_path, method: :patch, local: true, class: "d-flex gap-2 align-items-center" do %>
								<%= hidden_field_tag :product_id, item[:product].id %>
								<%= number_field_tag :quantity, item[:quantity], min: 1, class: "form-control", style: "width: 90px;" %>
								<%= submit_tag "Update", class: "btn btn-outline-secondary btn-sm" %>
							<% end %>
						</td>
						<td><%= number_to_currency(item[:product].cost) %></td>
						<td><%= number_to_currency(item[:item_total]) %></td>
						<td>
							<%= button_to "Remove", remove_item_orders_path(product_id: item[:product].id), method: :delete, class: "btn btn-outline-danger btn-sm" %>
						</td>
					</tr>
				<% end %>
			</tbody>
		</table>
	</div>

	<p class="fs-5 fw-bold">Cart Total: <%= number_to_currency(@cart_total) %></p>
	<p>
		<%= link_to "Continue Shopping", products_path, class: "shaded_links" %>
		<%= link_to "Checkout", checkout_orders_path, class: "links" %>
	</p>
<% else %>
	<p>Your shopping cart is currently empty.</p>
	<p><%= link_to "Browse Products", products_path, class: "links" %></p>
<% end %>
