<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Final Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav>
      <%= link_to "Home", root_path %> |
      <%= link_to "Products", products_path %> |
      <%= link_to "About", about_path %>

      <% if customer_signed_in? %>
        | <%= link_to "Orders", orders_path %>
        | <%= link_to "My Account", edit_customer_registration_path %>
        | <%= button_to "Logout", destroy_customer_session_path, method: :delete %>
      <% else %>
        | <%= link_to "Sign Up", new_customer_registration_path %>
        | <%= link_to "Login", new_customer_session_path %>
      <% end %>
    </nav>

    <% if notice %>
      <p><%= notice %></p>
    <% end %>

    <% if alert %>
      <p><%= alert %></p>
    <% end %>

    <%= yield %>
  </body>
</html>
